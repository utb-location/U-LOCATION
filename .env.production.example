APP_NAME="UTB Location Autocars"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://location.utb-ci.net

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=fr_FR

APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=daily
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=utb_location
DB_USERNAME=utb_location_user
DB_PASSWORD=CHANGE_ME

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

CACHE_STORE=database
QUEUE_CONNECTION=database
FILESYSTEM_DISK=local

MAIL_MAILER=smtp
MAIL_SCHEME=smtps
MAIL_HOST=mail.utb-ci.net
MAIL_PORT=465
MAIL_USERNAME=utb.location-af@utb-ci.net
MAIL_PASSWORD=CHANGE_ME
MAIL_FROM_ADDRESS=utb.location-af@utb-ci.net
MAIL_FROM_NAME="UTB Location Autocars"

SMS_DRIVER=orange
SMS_SENDER=UTBLOCATION
SMS_COUNTRY_CODE=225
ORANGE_API_BASE_URL=https://api.orange.com
ORANGE_CLIENT_ID=CHANGE_ME
ORANGE_CLIENT_SECRET=CHANGE_ME
ORANGE_SENDER_ADDRESS=CHANGE_ME
ORANGE_SENDER_NAME=UTBLOCATION

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-west-3
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
